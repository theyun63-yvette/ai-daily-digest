# ============================================================
# 每日AI资讯日报 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 注意: .env 文件已加入 .gitignore，不会被提交到仓库
# ============================================================

# GitHub Personal Access Token（可选但强烈建议配置）
# 未配置时 API 限额为 60 次/小时，配置后提升至 5000 次/小时
# 获取方式: https://github.com/settings/tokens → Generate new token (classic)
# 权限只需勾选 public_repo（公开仓库访问即可）
GITHUB_TOKEN=your_github_token_here

# DeepSeek API Key（可选）
# 用于生成 AI 锐评，未配置时自动 fallback 到智能模板
# 获取方式: https://platform.deepseek.com/ → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 企业微信机器人 Webhook URL（可选）
# 用于将日报推送到企业微信群
# 获取方式: 企业微信群 → 群设置 → 群机器人 → 添加机器人 → 复制 Webhook 地址
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
